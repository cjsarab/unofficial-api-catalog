{
  "name": "api-catalog-explorer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local, clone-and-run explorer for the Ellucian API catalog.",
  "scripts": {
    "start": "tsx server.ts",
    "dev": "concurrently -n srv,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch server.ts",
    "dev:web": "vite",
    "build:web": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@types/node": "^24.0.0",
    "concurrently": "^9.0.0",
    "svelte": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  }
}
