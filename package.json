{
  "name": "api-catalog-explorer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local, zero-install explorer for the Ellucian API catalog.",
  "scripts": {
    "launch": "bun run server.ts",
    "dev": "bun run --watch server.ts",
    "dev:web": "vite",
    "build:web": "vite build",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/bun": "latest",
    "svelte": "^5.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
