# Runtime + build artefacts
node_modules/
build/
.svelte-kit/
coverage/
.nyc_output/

# dist/ is committed so corporate-locked machines (no .exe execution allowed,
# i.e. AppLocker / WDAC) can run with `npm ci --omit=dev` + `npm run start` —
# skipping vite/esbuild entirely. We do ignore the sourcemaps to keep the
# committed artefact small.
dist/**/*.map

# Local scratch / throwaway dev artefacts (screenshots, notes, etc.)
docs/throwaway/

# User data (never commit)
APICatalog/
%APPDATA%/
/data/*
!/data/.gitkeep
*.sqlite
*.sqlite-*
*.sqlite3
*.db
index.sqlite
fixtures/real-catalog/

# Secrets — never commit these, ever.
# If a template is ever needed, allow-list via `!foo.example` on a specific file.
.env
.env.*
*.key
*.pem
*.p12
*.pfx
*.asc
*.gpg
*.crt
*.cer
secrets.json
credentials.json
credentials*.json
auth.json
api-key*
api_key*
*.secret
secret*.txt
id_rsa*
id_dsa*
id_ecdsa*
id_ed25519*
.aws/
.gcp/
.ssh/

# Tooling
.superpowers/
.claude/
.vscode/
.idea/
*.log
*.tmp

# Editor swap / backup files
*.swp
*.swo
*~
.history/
*.bak
*.orig

# OS cruft
Thumbs.db
desktop.ini
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
